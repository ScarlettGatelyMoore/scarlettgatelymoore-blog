---
const today = new Date();
---

<footer>
	<div class="footer-inner">
	<span class="copy">&copy; {today.getFullYear()} Scarlett Gately Moore</span>
<div class="social-links">
	<a href="mailto:sgmoore@debian.org">email</a>
<a href="https://github.com/scarlettgatelymoore" target="_blank">github</a>
<a href="https://www.linkedin.com/in/scarlettgatelymoore" target="_blank">linkedin</a>
</div>
</div>
</footer>

<style>
	footer {
	position: relative;
	z-index: 10;
	padding: 0 2rem;
	border-top: 1px solid var(--blue-border);
	background: transparent;
	}
	.footer-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	flex-wrap: wrap;
	gap: 1rem;
	max-width: 860px;
	margin: 0 auto;
	padding: 1.5rem 0;
	}
	.copy {
	font-family: 'Space Mono', monospace;
	font-size: 11px;
	color: var(--text-dim);
	letter-spacing: 0.03em;
	}
	.social-links {
	display: flex;
	gap: 1.5rem;
	}
	.social-links a {
	font-family: 'Space Mono', monospace;
	font-size: 11px;
	color: var(--text-muted);
	text-decoration: none;
	letter-spacing: 0.03em;
	transition: color 0.2s;
	}
	.social-links a:hover { color: var(--accent); }
</style>

---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="logo">sgmoore<span>@</span>scarlettgatelymoore.dev</a>
    <div class="internal-links">
      <HeaderLink href="/blog">writing</HeaderLink>
      <HeaderLink href="/about">about</HeaderLink>
      <a href="https://github.com/scarlettgatelymoore" target="_blank">github</a>
    </div>
  </nav>
</header>

<style>
  header {
    position: relative;
    z-index: 10;
    margin: 0;
    padding: 0 2rem;
    background: transparent;
    border-bottom: 1px solid var(--blue-border);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 860px;
    margin: 0 auto;
    padding: 1.25rem 0;
  }
  .logo {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  .logo span { color: var(--text-muted); }
  .internal-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .internal-links a {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    border-bottom: none;
    padding: 0;
    transition: color 0.2s;
  }
  .internal-links a:hover,
  .internal-links a.active {
    color: var(--accent);
    border-bottom: none;
  }
</style>

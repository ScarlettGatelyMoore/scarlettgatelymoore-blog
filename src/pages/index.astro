---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .grid-bg {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(55,138,221,0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(55,138,221,0.04) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }
      .orb {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(24,95,165,0.15) 0%, transparent 70%);
        top: -200px;
        right: -200px;
        pointer-events: none;
        z-index: 0;
      }
      .orb2 {
        position: fixed;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(55,138,221,0.08) 0%, transparent 70%);
        bottom: 0;
        left: -100px;
        pointer-events: none;
        z-index: 0;
      }
      main {
        position: relative;
        z-index: 1;
        max-width: 860px;
        width: calc(100% - 4rem);
        margin: 0 auto;
        padding: 4rem 0;
      }
      .hero {
        margin-bottom: 4rem;
        animation: fadeUp 0.6s ease forwards;
      }
      .hero-tag {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--accent);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .hero-tag::before {
        content: '';
        display: inline-block;
        width: 24px;
        height: 1px;
        background: var(--accent);
      }
      .hero h1 {
        font-family: 'Space Mono', monospace;
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 1.5rem;
      }
      .hero h1 .accent { color: var(--accent); }
      .hero h1 .dim { color: var(--text-dim); }
      .hero-desc {
        font-size: 17px;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 560px;
        margin-bottom: 2.5rem;
        font-weight: 300;
      }
      .hero-desc strong { color: var(--text); font-weight: 500; }
      .cta-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }
      .btn {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.05em;
        padding: 0.75rem 1.5rem;
        border-radius: 4px;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
      }
      .btn-primary {
        background: var(--accent-dark);
        color: #b5d4f4;
        border: 1px solid var(--accent);
      }
      .btn-primary:hover { background: var(--accent); color: #042c53; }
      .btn-ghost {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--blue-border);
      }
      .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
      .stack-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .tag {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 3px;
        background: var(--blue-glow);
        border: 1px solid var(--blue-border);
        color: var(--text-muted);
        letter-spacing: 0.03em;
      }
      .divider {
        height: 1px;
        background: linear-gradient(90deg, var(--blue-border), transparent);
        margin: 3rem 0;
      }
      .section-label {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--accent);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 0;
        animation: fadeUp 0.7s 0.1s ease both;
      }
      @media (max-width: 700px) {
        .cards { grid-template-columns: 1fr; }
      }
      .card {
        background: var(--bg2);
        border: 1px solid var(--blue-border);
        border-radius: 6px;
        padding: 1.25rem;
        transition: border-color 0.2s, background 0.2s;
      }
      .card:hover { border-color: var(--accent); background: var(--bg3); }
      .card-icon {
        font-family: 'Space Mono', monospace;
        font-size: 18px;
        color: var(--accent);
        margin-bottom: 0.75rem;
      }
      .card h3 {
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
        letter-spacing: 0.02em;
      }
      .card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }
      .card .meta {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--text-dim);
        margin-top: 0.75rem;
        letter-spacing: 0.05em;
      }
      .posts {
        display: flex;
        flex-direction: column;
        border: 1px solid var(--blue-border);
        border-radius: 6px;
        overflow: hidden;
        animation: fadeUp 0.7s 0.2s ease both;
      }
      .post-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--blue-border);
        transition: background 0.15s;
        text-decoration: none;
        gap: 1rem;
      }
      .post-row:last-child { border-bottom: none; }
      .post-row:hover { background: var(--bg3); }
      .post-title { font-size: 14px; color: var(--text); font-weight: 400; }
      .post-date {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--text-dim);
        white-space: nowrap;
        letter-spacing: 0.03em;
      }
      .post-tag {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 3px;
        background: var(--blue-glow);
        border: 1px solid var(--blue-border);
        color: var(--accent);
        white-space: nowrap;
      }
      .cursor {
        display: inline-block;
        width: 2px;
        height: 0.85em;
        background: var(--accent);
        margin-left: 4px;
        vertical-align: middle;
        animation: blink 1s step-end infinite;
      }
      .donate-row {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .donate-desc {
        font-size: 14px;
        color: var(--text-muted);
        margin: 0;
      }
      @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <div class="grid-bg"></div>
    <div class="orb"></div>
    <div class="orb2"></div>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-tag">open source developer</div>
        <h1>
          Scarlett<br>
          <span class="accent">Gately Moore</span><span class="cursor"></span><br>
          <span class="dim">BA(CIS)</span>
        </h1>
        <p class="hero-desc">
          <strong>Debian Developer</strong> and Linux distribution specialist with 11+ years
          building CI/CD infrastructure, packaging software, and leading release management
          across Kubuntu, KDE, and Debian. Currently venturing into
          <strong>Apache County property appraisal</strong> in St. Johns, Arizona.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/blog">./read --blog</a>
          <a class="btn btn-ghost" href="/blog">./view --projects</a>
          <a class="btn btn-ghost" href="/about">./about --me</a>
        </div>
        <div class="stack-row">
          <span class="tag">debian</span>
          <span class="tag">kubuntu</span>
          <span class="tag">kde</span>
          <span class="tag">python</span>
          <span class="tag">ruby</span>
          <span class="tag">bash</span>
          <span class="tag">jenkins</span>
          <span class="tag">docker</span>
          <span class="tag">lxd</span>
          <span class="tag">snap</span>
          <span class="tag">appimage</span>
          <span class="tag">arm64</span>
          <span class="tag">amd64</span>
        </div>
      </section>

      <div class="divider"></div>

      <div class="section-label">// areas</div>
      <div class="cards">
        <div class="card">
          <div class="card-icon">[&gt;_]</div>
          <h3>distribution engineering</h3>
          <p>Release management, packaging pipelines, and multi-arch builds for Kubuntu, Debian, and Netrunner.</p>
          <div class="meta">11+ YRS EXPERIENCE</div>
        </div>
        <div class="card">
          <div class="card-icon">[CI]</div>
          <h3>devops &amp; infrastructure</h3>
          <p>CI/CD architecture with Jenkins and GitLab. Built systems supporting hundreds of KDE applications worldwide.</p>
          <div class="meta">KDE // BLUE SYSTEMS</div>
        </div>
        <div class="card">
          <div class="card-icon">[AZ]</div>
          <h3>property appraisal</h3>
          <p>Property Appraiser I with Apache County, Arizona. Dual valuation system, legal classifications, and assessment ratios.</p>
          <div class="meta">ST. JOHNS, ARIZONA</div>
        </div>
      </div>

      <div class="divider"></div>

      <div class="section-label">// recent writing</div>
      <div class="posts">
        {posts.map((post) => (
          <a class="post-row" href={`/blog/${post.id}/`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-tag">{post.data.tags?.[0] ?? 'post'}</span>
            <span class="post-date">{post.data.pubDate.toISOString().slice(0, 10)}</span>
          </a>
        ))}
      </div>
      <div class="divider"></div>

      <div class="section-label">// support the work</div>
      <div class="donate-row">
        <p class="donate-desc">Kubuntu and open source work is volunteer-powered. If you find value in it, consider supporting:</p>
        <a class="dbox-donation-page-button" href="https://donorbox.org/open-source-work?" style="background: rgb(18, 138, 237); color: rgb(255, 255, 255); text-decoration: none; font-family: Verdana, sans-serif; display: flex; align-items: center; gap: 8px; width: fit-content; font-size: 16px; border-radius: 5px; line-height: 24px; padding: 8px 24px;">
          <img role="presentation" src="https://donorbox.org/images/white_logo.svg" style="width:18px;height:18px;">Donate
        </a>
      </div>
    </main>
    <Footer />
  </body>
</html>

---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags } = Astro.props;

const formattedDate = pubDate.toISOString().slice(0, 10);
const formattedUpdated = updatedDate ? updatedDate.toISOString().slice(0, 10) : null;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .grid-bg {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(55,138,221,0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(55,138,221,0.04) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }
      .orb {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(24,95,165,0.15) 0%, transparent 70%);
        top: -200px;
        right: -200px;
        pointer-events: none;
        z-index: 0;
      }
      main {
        position: relative;
        z-index: 1;
        max-width: 720px;
        width: calc(100% - 4rem);
        margin: 0 auto;
        padding: 4rem 0;
        animation: fadeUp 0.6s ease forwards;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--text-dim);
        text-decoration: none;
        letter-spacing: 0.03em;
        margin-bottom: 2.5rem;
        transition: color 0.2s;
      }
      .back-link:hover { color: var(--accent); }
      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
      }
      .post-tag {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 3px;
        background: rgba(55,138,221,0.12);
        border: 1px solid rgba(55,138,221,0.25);
        color: var(--accent);
        letter-spacing: 0.05em;
      }
      .post-date {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 0.05em;
      }
      .post-updated {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 0.03em;
        font-style: italic;
      }
      h1 {
        font-family: 'Space Mono', monospace;
        font-size: clamp(1.6rem, 4vw, 2.4rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
        margin-bottom: 2.5rem;
      }
      .divider {
        height: 1px;
        background: linear-gradient(90deg, rgba(55,138,221,0.25), transparent);
        margin-bottom: 2.5rem;
      }
      .prose {
        color: var(--text-muted);
      }
      .prose :global(h2) {
        font-family: 'Space Mono', monospace;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(55,138,221,0.25);
      }
      .prose :global(h3) {
        font-family: 'Space Mono', monospace;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text);
        margin: 2rem 0 0.75rem;
      }
      .prose :global(p) {
        font-size: 16px;
        line-height: 1.85;
        margin-bottom: 1.4rem;
        color: var(--text-muted);
      }
      .prose :global(strong) {
        color: var(--text);
        font-weight: 500;
      }
      .prose :global(a) {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid rgba(55,138,221,0.25);
        transition: border-color 0.2s;
      }
      .prose :global(a:hover) {
        border-bottom-color: var(--accent);
      }
      .prose :global(ul) {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .prose :global(ul li) {
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.7;
        padding-left: 1.5rem;
        position: relative;
      }
      .prose :global(ul li::before) {
        content: '//';
        position: absolute;
        left: 0;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--accent);
        top: 4px;
      }
      .prose :global(ol) {
        padding-left: 1.5rem;
        margin: 0 0 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .prose :global(ol li) {
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.7;
      }
      .prose :global(blockquote) {
        border-left: 3px solid var(--accent);
        margin: 1.5rem 0;
        padding: 0.75rem 1.25rem;
        background: var(--bg2);
        border-radius: 0 6px 6px 0;
        font-size: 15px;
        color: var(--text-muted);
      }
      .prose :global(code) {
        font-family: 'Space Mono', monospace;
        font-size: 0.85em;
        padding: 2px 6px;
        background: var(--bg2);
        border: 1px solid rgba(55,138,221,0.25);
        border-radius: 3px;
        color: var(--accent);
      }
      .prose :global(pre) {
        background: var(--bg2);
        border: 1px solid rgba(55,138,221,0.25);
        border-radius: 6px;
        padding: 1.25rem 1.5rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }
      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 13px;
        color: var(--text-muted);
      }
      .prose :global(hr) {
        border: none;
        border-top: 1px solid rgba(55,138,221,0.25);
        margin: 2rem 0;
      }
      .author-bio {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(55,138,221,0.25);
        font-size: 14px;
        color: var(--text-dim);
        font-family: 'Space Mono', monospace;
        letter-spacing: 0.02em;
      }
      .author-bio a {
        color: var(--accent);
        text-decoration: none;
      }
      .author-bio a:hover { text-decoration: underline; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <div class="grid-bg"></div>
    <div class="orb"></div>
    <Header />
    <main>
      <a class="back-link" href="/blog">&larr; back to writing</a>

      <div class="post-meta">
        {tags && tags.map((tag) => (
          <span class="post-tag">{tag}</span>
        ))}
        <span class="post-date">{formattedDate}</span>
        {formattedUpdated && (
          <span class="post-updated">updated {formattedUpdated}</span>
        )}
      </div>

      <h1>{title}</h1>
      <div class="divider"></div>

      <div class="prose">
        <slot />
      </div>

      <div class="author-bio">
        // <a href="/about">Scarlett Gately Moore</a> — Debian Developer, St. Johns AZ
      </div>
    </main>
    <Footer />
  </body>
</html>
